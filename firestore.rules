rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /users/{userId}/studyLogs/{logId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /users/{userId}/plannerTasks/{taskId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /test/{docId} {
      allow read: if true;
    }
  }
}
